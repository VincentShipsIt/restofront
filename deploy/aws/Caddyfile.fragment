# BEGIN RESTOFRONT
restofront.com {
	@workflowHandlers path /.well-known/workflow/v1/flow* /.well-known/workflow/v1/step*
	respond @workflowHandlers 404
	reverse_proxy restofront:3000
}

www.restofront.com {
	redir https://restofront.com{uri} permanent
}

domains.restofront.com {
	respond 404
}

https:// {
	tls {
		on_demand
	}
	@workflowHandlers path /.well-known/workflow/v1/flow* /.well-known/workflow/v1/step*
	respond @workflowHandlers 404
	reverse_proxy restofront:3000
}
# END RESTOFRONT
